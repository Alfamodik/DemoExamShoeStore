@page
@model ShoeStore.Web.Pages.OrdersModel
@{
    Layout = null;
    ViewData["UserId"] = Model.UserId;
    ViewData["AccessRights"] = Model.AccessRights;
}

<div style="padding:16px; max-width:1200px; margin:0 auto;">
    <div style="display:flex; align-items:center; gap:16px; margin-bottom:16px;">
        <img src="~/Resources/Icon.png" style="height:80px;" alt="icon" />
        <h1 style="flex:1; text-align:center; font-size:40px;">Заказы</h1>

        @if (Model.AccessRights == ShoeStore.Core.AccessRights.Admin)
        {
            <a asp-page="/OrderEdit" asp-route-userId="@Model.UserId" asp-route-accessRights="@Model.AccessRights" class="btn" style="background:MediumSpringGreen; padding:8px 14px; text-decoration:none;">Создать</a>
        }
        <a asp-page="/SearchCatalog" asp-route-userId="@Model.UserId" asp-route-accessRights="@Model.AccessRights" class="btn" style="background:MediumSpringGreen; padding:8px 14px; text-decoration:none;">Назад</a>
    </div>

    <div>
        @if (Model.Orders?.Any() != true)
        {
            <p>Заказов нет.</p>
        }
        else
        {
            <div style="display:flex; flex-direction:column; gap:8px;">
                @foreach (Model.Order order in Model.Orders)
                {
                    <partial name="OrderUserControl" model="order" />
                }
            </div>
        }
    </div>
</div>
<script>
    function openOrderItemsModal(elementId) {
        document.getElementById(elementId).style.display = "block";
    }

    function closeOrderItemsModal(elementId) {
        document.getElementById(elementId).style.display = "none";
    }
</script>